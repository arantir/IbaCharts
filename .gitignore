# ============================================
# Gradle и файлы сборки
# ============================================

# Системные папки Gradle (локальный кеш, не должен быть в репозитории)
.gradle/

# Папки сборки всех модулей
build/
*/build/
app/build/
data/build/
domain/build/
presentation/build/

# Локальные настройки Gradle (пути, ключи)
local.properties
gradle-wrapper.jar
gradle/wrapper/gradle-wrapper.jar

# Временные и бинарные файлы сборки
*.dex
*.ap_
*.flat
*.jar
*.aar
*.class
*.lock
*.bin
*.log
*.temp
*.tmp
*.exp
*.met
*.tag
*.timestamp
*.compiler.options

# Отчеты о сборке и тестах
**/reports/
**/problems-report.html

# Кеши и промежуточные файлы
**/caches/
**/cacheable/
**/classpath-snapshot/

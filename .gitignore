# ============================================
# Файлы, которые НУЖНО сохранять (исключения)
# ============================================

# APK файлы (сохраняем, но лучше не хранить в Git из-за размера)
!**/*.apk

# Gradle Wrapper (если используешь) — рекомендую хранить, но закомментировано
# !gradle/wrapper/gradle-wrapper.jar
# !gradlew
# !gradlew.bat